<Window x:Class="WpfMySetProjects.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfMySetProjects"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Loaded="Window_loaded">
    <Grid>
        <Button Name="ButtonButton" Content="Button" 
                HorizontalAlignment="Left" Margin="618,10,0,0" 
                VerticalAlignment="Top" Height="40" Width="140"
                Click="ButtonButton_Click"/>

        <ComboBox Name="leftSet" HorizontalAlignment="Left" 
                  Margin="10,10,0,0" VerticalAlignment="Top" Width="150"
                  SelectionChanged="leftSet_SelectionChanged"/>

        <ComboBox Name="operation" HorizontalAlignment="Left" 
                  Margin="200,10,0,0" VerticalAlignment="Top" Width="150"/>

        <ComboBox Name="rightSet" HorizontalAlignment="Left" 
                  Margin="390,10,0,0" VerticalAlignment="Top" Width="150"
                  SelectionChanged="rightSet_SelectionChanged"/>

        <ListBox Name="leftMembers" HorizontalAlignment="Left"
                 Margin="10,60,0,10" Width="150" VerticalAlignment="Stretch"/>

        <ListBox Name="resultSet" HorizontalAlignment="Left"
                 Margin="200,60,0,10" Width="150" VerticalAlignment="Stretch"/>

        <ListBox Name="rightMembers" HorizontalAlignment="Left"
                 Margin="390,60,0,10" Width="150" VerticalAlignment="Stretch"/>
    </Grid>
</Window>